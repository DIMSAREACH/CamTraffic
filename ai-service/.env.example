# AI Service environment variables
# Loaded from monorepo root .env when running via Docker

AI_SERVICE_PORT=8001
AI_MODEL_PATH=models
AI_YOLO_WEIGHTS=yolov11_camtraffic_v1.pt
AI_YOLO_DEVICE=cpu
AI_DETECTION_MODE=auto
AI_OCR_MODE=auto
AI_OCR_LANGUAGES=en
AI_PROCESSING_MAX_WIDTH=1280
AI_PIPELINE_STORE_RESULTS=true
AI_STORAGE_PATH=data/detections
AI_CONFIDENCE_THRESHOLD=0.75
BACKEND_URL=http://localhost:8000
