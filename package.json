{
  "name": "camtraffic",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Based Traffic Sign Detection and Traffic Law Enforcement System in Cambodia",
  "workspaces": [
    "frontend-admin",
    "frontend-user",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:admin": "npm run dev --workspace=frontend-admin",
    "dev:user": "npm run dev --workspace=frontend-user",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@camtraffic/*",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "validate": "node scripts/validate-structure.mjs",
    "validate:all": "npm run validate && npm run validate:env && npm run validate:locales",
    "validate:locales": "node scripts/validate-locales.mjs",
    "setup:env": "node scripts/setup-env.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "python -m pytest",
    "test:frontend": "vitest run --config tests/vitest.config.ts",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "npm run test:e2e:install && playwright test --config tests/e2e/playwright.config.mjs",
    "test:performance": "node tests/performance/health-benchmark.mjs",
    "test:all": "npm run test && npm run test:e2e",
    "scaffold": "node scripts/scaffold-folders.mjs",
    "docker:postgres": "docker compose up postgres -d",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:reset": "docker compose down -v",
    "docker:prod:up": "docker compose -f deploy/docker/docker-compose.prod.yml --env-file .env.production up --build -d",
    "docker:prod:down": "docker compose -f deploy/docker/docker-compose.prod.yml --env-file .env.production down",
    "docker:prod:logs": "docker compose -f deploy/docker/docker-compose.prod.yml --env-file .env.production logs -f",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^26.1.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.7.0"
}
