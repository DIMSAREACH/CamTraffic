{
  "name": "camtraffic",
  "private": true,
  "description": "CamTraffic — AI traffic sign detection & enforcement (Cambodia)",
  "workspaces": [
    "src/web/admin",
    "src/web/user",
    "src/web/citizen",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx --yes concurrently -k -n user,admin -c blue,magenta \"npm run dev:user\" \"npm run dev:admin\"",
    "dev:clean": "node scripts/clear-vite-cache.mjs && npm run dev",
    "dev:user": "npm run dev --prefix src/web/user",
    "dev:admin": "npm run dev --prefix src/web/admin",
    "dev:citizen": "npm run dev --prefix src/web/citizen",
    "build": "npm run build:user && npm run build:admin",
    "build:turbo": "turbo run build",
    "build:user": "npm run build --prefix src/web/user",
    "build:admin": "npm run build --prefix src/web/admin",
    "build:citizen": "npm run build --prefix src/web/citizen",
    "install:frontends": "npm install -w src/web/user -w src/web/admin",
    "validate:structure": "node scripts/validate-structure.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "validate:production-data": "node scripts/validate-production-data-mode.mjs",
    "verify:phase1": "node scripts/validate-production-data-mode.mjs && node scripts/backend-python.mjs scripts/verify_phase1.py",
    "sync:shared:check": "node scripts/sync-shared-check.mjs",
    "setup:env": "node scripts/setup-env.mjs",
    "scaffold:folders": "node scripts/scaffold-folders.mjs",
    "validate:all": "npm run validate:structure && npm run validate:env && npm run build && npm run test:backend",
    "validate:system": "node scripts/validate-full-system.mjs",
    "validate:detection": "node scripts/validate-detection-stack.mjs",
    "validate:ai-thesis": "node scripts/validate-ai-thesis.mjs",
    "validate:production": "node scripts/validate-production-platform.mjs",
    "validate:payments-data-ocr": "node scripts/validate-payments-data-ocr.mjs",
    "validate:real-data": "node scripts/validate-real-data-system.mjs",
    "seed:demo": "node scripts/backend-python.mjs manage.py seed_demo",
    "seed:production": "node scripts/backend-python.mjs manage.py seed_production",
    "audit:api": "node scripts/backend-python.mjs manage.py audit_api_permissions",
    "test:backend": "node scripts/backend-python.mjs manage.py test --noinput",
    "test:backend:phase12": "node scripts/backend-python.mjs manage.py test tests.backend tests.api.test_health_auth_users tests.integration tests.security tests.test_officer_only_fines -v 2 --noinput --keepdb",
    "test:frontend-admin": "npm run test --prefix src/web/admin",
    "test:frontend-user": "npm run test --prefix src/web/user",
    "test:frontend": "npm run test:frontend-admin && npm run test:frontend-user",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:officer-ai": "node scripts/run-e2e.mjs -- --project=user-chromium officer-ai-detection.spec.ts",
    "benchmark:health": "node tests/performance/health-benchmark.mjs",
    "docker:prod:up": "node scripts/docker-prod.mjs up",
    "docker:prod:down": "node scripts/docker-prod.mjs down",
    "docker:prod:logs": "node scripts/docker-prod.mjs logs",
    "docker:prod:restart": "node scripts/docker-prod.mjs restart",
    "docker:prod:ps": "node scripts/docker-prod.mjs ps",
    "local:prod:up": "node scripts/local-prod.mjs up",
    "local:prod:down": "node scripts/local-prod.mjs down"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.3.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.2"
  },
  "allowScripts": {
    "@tailwindcss/oxide@4.3.3": true,
    "esbuild@0.25.12": true,
    "sharp@0.34.5": true
  }
}
