DEBUG=True
SECRET_KEY=change-me-to-a-long-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=camtraffic_db
DB_USER=postgres
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=5432

# Use SQLite for quick local dev (set USE_SQLITE=True)
USE_SQLITE=False

# Redis (set USE_REDIS=True when running docker-compose or local Redis)
USE_REDIS=False
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000,http://127.0.0.1:3000

# JWT (minutes)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# OAuth — Google: Cloud Console → Credentials → OAuth client ID (Web app), NOT API key
# Redirect URI in Google must be: http://localhost:5173/auth/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/auth/oauth/callback

# Password reset link in emails (user portal)
FRONTEND_PASSWORD_RESET_URL=http://localhost:5173/reset-password

# Public API origin (production). Used to build absolute /media/ URLs for SPAs.
# PUBLIC_API_URL=https://camtraffic-api.onrender.com
# SERVE_MEDIA=True

# ── Free cloud media (Cloudflare R2 — recommended for Render) ─────────────────
# Setup: docs/CLOUD-MEDIA-R2.md  |  Free tier: 10 GB storage, no egress fees
# USE_S3_MEDIA=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=camtraffic-media
# AWS_S3_REGION_NAME=auto
# AWS_S3_ENDPOINT_URL=https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=pub-REPLACE.r2.dev
# AWS_LOCATION=media

# Resend (recommended) — https://resend.com → API Keys. See docs/RESEND_EMAIL_SETUP.md
RESEND_API_KEY=re_xxxxxxxx
# Must be a full address: Name <user@verified-domain.com>
RESEND_FROM_EMAIL=CamTraffic <noreply@camtraffic.store>

# SMTP fallback (optional if not using Resend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Enterprise v2 — FastAPI AI microservice (optional; empty = embedded Django pipeline)
# AI_VISION_SERVICE_URL=http://localhost:8080

# Enterprise v2 — OCR microservice (optional; empty = embedded EasyOCR)
# OCR_SERVICE_URL=http://localhost:8081

# Enterprise v2 — RTSP stream gateway (optional)
# STREAM_GATEWAY_URL=http://localhost:8082

# ── Option 1 (Runtime = full 248-class catalog model) ─────────────
# Offline pipeline: Webcam → OpenCV → YOLO signs → YOLO vehicles → EasyOCR → Violations → PostgreSQL
# Live inference = 248-class best.pt. Thesis mAP@50=0.908 is for best_v2.pt only — see docs/AI-MODEL-STORY.md
AI_DETECTION_MODE=local
AI_MODEL_PATH=../ai/weights/best.pt
# Optional 10-class evaluated subset (cite mAP@50=0.908 only with this file):
# AI_MODEL_PATH=../ai/weights/best_v2.pt
# Optional: force catalog file
# AI_SIGN_CATALOG_PATH=../ai/sign_catalog.json
AI_USE_MOCK=False
AI_CONFIDENCE_THRESHOLD=0.35
AI_MIN_RESULT_CONFIDENCE=35
AI_LIVE_YOLO_FLOOR=10
AI_LIVE_YOLO_INFER_CONF=0.50
AI_LIVE_YOLO_TRUST=50
AI_LIVE_YOLO_CATALOG_MIN=45
# Shape heuristics: mainly for small-class models; keep False for large catalog weights
AI_SHAPE_HINTS_ENABLED=False
AI_LIVE_IMGSZ=640
AI_CATALOG_VISUAL_MATCH_ENABLED=True
AI_CATALOG_VISUAL_MIN_SCORE=0.58
AI_CATALOG_VISUAL_LIVE_MIN_SCORE=0.62
AI_CATALOG_VISUAL_MIN_MARGIN=0.04
AI_LIVE_SIGN_COLOR_MIN=0.05
AI_LIVE_SIGN_BLOB_MIN=0.025
AI_LIVE_SKIN_MAX=0.38
AI_LIVE_EDGE_MIN=0.008
AI_IMGSZ=640
AI_UPLOAD_YOLO_FLOOR=35
AI_HYBRID_CONFIDENCE_THRESHOLD=70
AI_GEMINI_UPLOAD_FALLBACK=False
AI_GEMINI_LIVE_FALLBACK=False
AI_UPLOAD_MAX_EDGE=1280
# Max video upload size for AI detection (MB). Keep in sync with frontend VideoUploadPanel.
AI_VIDEO_MAX_MB=500

# Vehicle detection (YOLOv8 COCO pretrained — car, motorcycle, bus, truck)
AI_VEHICLE_ENABLED=True
AI_VEHICLE_MODEL=yolov8n.pt
AI_VEHICLE_CONFIDENCE_THRESHOLD=0.35
AI_VEHICLE_TRACKING_ENABLED=True

# License plate OCR (EasyOCR — Cambodia Latin plates e.g. 2A-1234)
AI_PLATE_OCR_ENABLED=True
AI_PLATE_OCR_MIN_CONFIDENCE=0.45
AI_PLATE_OCR_LANGUAGES=en

# Full demo pipeline — auto violation check + record when plate links to a driver
AI_PIPELINE_DEMO_VIOLATION=True
AI_PIPELINE_AUTO_CREATE_VIOLATION=True

# ── Option 2 (Optional backup only — not for defense demo) ─────────
# Set AI_DETECTION_MODE=hybrid and enable flags below to use Gemini when YOLO is uncertain.
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_ENABLED=True
# AI_GEMINI_UPLOAD_FALLBACK=True
# AI_GEMINI_LIVE_FALLBACK=True
GEMINI_API_KEY=
GEMINI_ENABLED=False
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUEST_TIMEOUT=30
GEMINI_BACKOFF_SECONDS=60

# Neural TTS — Khmer + English (edge-tts; needs internet)
TTS_ENABLED=True
TTS_VOICE=km-KH-SreymomNeural
TTS_VOICE_EN=en-US-JennyNeural
TTS_RATE=-5%

# Live payments — ABA KHQR (static QR in frontend-user/public/payments/aba-khqr.png)
PAYMENT_MODE=khqr
PAYMENT_CURRENCY=usd
PAYMENT_MANUAL_PROOF_ENABLED=True
KHQR_MERCHANT_NAME=SAREACH DIM
KHQR_MERCHANT_ACCOUNT=005347359
KHQR_MERCHANT_ACCOUNT_KHR=005347360
KHQR_QR_IMAGE_URL=/payments/aba-khqr.png
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# API security & documentation (Phase 2)
ENABLE_API_DOCS=True
# Dev defaults are raised in settings.py when DEBUG=True; override here if needed.
API_THROTTLE_ANON=600/min
API_THROTTLE_BURST=1200/min
API_THROTTLE_SUSTAINED=50000/hour
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW=300
