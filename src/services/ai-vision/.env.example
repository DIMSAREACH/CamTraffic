# AI Vision Service
AI_VISION_HOST=0.0.0.0
AI_VISION_PORT=8080
AI_MOCK_MODE=false

# Paths (relative to repo root when running locally)
AI_ROOT=../../ai
AI_WEIGHTS_PATH=../../ai/weights/best.pt
AI_SIGN_CATALOG_PATH=../../ai/sign_catalog.json

# Inference
AI_CONFIDENCE_THRESHOLD=0.5
AI_OCR_ENABLED=true
AI_OCR_MIN_CONFIDENCE=0.75

# Optional downstream OCR microservice (Phase 3)
OCR_SERVICE_URL=
