# Thesis-aligned AI inference service (YOLOv8 + EasyOCR)
FROM python:3.11-slim-bookworm

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 libsm6 libxext6 libxrender1 \
    && rm -rf /var/lib/apt/lists/*

COPY src/services/ai-service/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY src/services/ai-service/ /app/

ENV AI_HOST=0.0.0.0
ENV AI_PORT=8090
ENV AI_WEIGHTS_PATH=/weights/best.pt
ENV AI_SIGN_CATALOG_PATH=/ai/sign_catalog.json
ENV PYTHONUNBUFFERED=1

EXPOSE 8090
CMD ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8090"]
