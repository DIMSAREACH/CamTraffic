# CamTraffic — Render Web Service (camtraffic-api)
# Paste into Render → Environment → "Add from .env" (replace REPLACE_* values).
# Never commit real secrets to Git.

# ── Django ────────────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=REPLACE_SECRET_KEY
ALLOWED_HOSTS=camtraffic-api.onrender.com,.onrender.com
DJANGO_SETTINGS_MODULE=camtraffic.settings_production
DJANGO_LOG_LEVEL=INFO
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ── PostgreSQL (Render internal host) ─────────────────────────────────────────
USE_SQLITE=False
DB_NAME=REPLACE_PG_DATABASE
DB_USER=REPLACE_PG_USER
DB_PASSWORD=REPLACE_PG_PASSWORD
DB_HOST=REPLACE_PG_INTERNAL_HOST
DB_PORT=5432
DB_CONN_MAX_AGE=120

# ── Redis (Render Key Value / internal URL) ───────────────────────────────────
USE_REDIS=True
REDIS_URL=REPLACE_REDIS_URL/0
CELERY_BROKER_URL=REPLACE_REDIS_URL/1
CELERY_RESULT_BACKEND=REPLACE_REDIS_URL/1

# ── CORS + frontend callbacks ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://camtraffic-admin.onrender.com,https://camtraffic-user.onrender.com,https://admin.camtraffic.store,https://app.camtraffic.store
PUBLIC_API_URL=https://camtraffic-api.onrender.com
SERVE_MEDIA=True
OAUTH_FRONTEND_CALLBACK_URL=https://camtraffic-user.onrender.com/auth/oauth/callback
FRONTEND_PASSWORD_RESET_URL=https://camtraffic-user.onrender.com/reset-password

# ── Free cloud media (Cloudflare R2) — survives Render redeploys ──────────────
# Docs: docs/CLOUD-MEDIA-R2.md
# When enabled, set SERVE_MEDIA=False (auto when USE_S3_MEDIA=True).
# USE_S3_MEDIA=True
# AWS_ACCESS_KEY_ID=REPLACE_R2_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=REPLACE_R2_SECRET_KEY
# AWS_STORAGE_BUCKET_NAME=camtraffic-media
# AWS_S3_REGION_NAME=auto
# AWS_S3_ENDPOINT_URL=https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=pub-REPLACE.r2.dev
# AWS_LOCATION=media

# ── JWT + API limits ──────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
ENABLE_API_DOCS=False
API_THROTTLE_ANON=60/min
API_THROTTLE_BURST=120/min
API_THROTTLE_SUSTAINED=2000/hour
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW=300

# ── Gunicorn ──────────────────────────────────────────────────────────────────
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ── AI (mock on Render until weights are on disk) ─────────────────────────────
AI_DETECTION_MODE=local
AI_MODEL_PATH=/app/ai/weights/best_v2.pt
AI_USE_MOCK=True
AI_WARMUP_MODELS=False
# Keep False on Render hobby (OOM). Real YOLO needs a larger plan + mounted weights.
AI_VEHICLE_ENABLED=False
AI_PLATE_OCR_ENABLED=False
AI_CONFIDENCE_THRESHOLD=0.35
AI_PIPELINE_AUTO_CREATE_VIOLATION=True
GEMINI_ENABLED=False
TTS_ENABLED=True

# ── OAuth (optional — Google / GitHub social login on user portal) ─────────────
# Add the same callback URL in Google Cloud + GitHub OAuth App settings:
#   https://camtraffic-user.onrender.com/auth/oauth/callback
# Optional custom domain:
#   https://app.camtraffic.store/auth/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=REPLACE_RESEND_API_KEY
RESEND_FROM_EMAIL=CamTraffic <noreply@your-verified-domain.com>
DEFAULT_FROM_EMAIL=CamTraffic <noreply@your-verified-domain.com>

# ── Hosted boot (no Render Shell) ─────────────────────────────────────────────
CAMTRAFFIC_SYNC_DEMO_ACCOUNTS=true
CAMTRAFFIC_BOOTSTRAP_ADMIN_EMAIL=you@example.com
CAMTRAFFIC_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_STRONG_PASSWORD
CAMTRAFFIC_BOOTSTRAP_ADMIN_NAME=Administrator
