# Render API — custom domain api.camtraffic.store
# Paste into camtraffic-api → Environment (replace REPLACE_*).
# Static sites: VITE_API_URL=https://api.camtraffic.store/api
# Full runbook: deploy/CAMTRAFFIC-STORE.md

DEBUG=False
SECRET_KEY=REPLACE_SECRET_KEY
ALLOWED_HOSTS=api.camtraffic.store,camtraffic-api.onrender.com,.onrender.com
DJANGO_SETTINGS_MODULE=camtraffic.settings_production
DJANGO_LOG_LEVEL=INFO
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

USE_SQLITE=False
DB_NAME=REPLACE_PG_DATABASE
DB_USER=REPLACE_PG_USER
DB_PASSWORD=REPLACE_PG_PASSWORD
DB_HOST=REPLACE_PG_INTERNAL_HOST
DB_PORT=5432
DB_CONN_MAX_AGE=120

USE_REDIS=True
REDIS_URL=REPLACE_REDIS_URL/0
CELERY_BROKER_URL=REPLACE_REDIS_URL/1
CELERY_RESULT_BACKEND=REPLACE_REDIS_URL/1

CORS_ALLOWED_ORIGINS=https://admin.camtraffic.store,https://app.camtraffic.store
PUBLIC_API_URL=https://api.camtraffic.store
SERVE_MEDIA=True
OAUTH_FRONTEND_CALLBACK_URL=https://app.camtraffic.store/auth/oauth/callback
FRONTEND_PASSWORD_RESET_URL=https://app.camtraffic.store/reset-password

# ── Free cloud media (Cloudflare R2) — docs/CLOUD-MEDIA-R2.md ─────────────────
# USE_S3_MEDIA=True
# AWS_ACCESS_KEY_ID=REPLACE_R2_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=REPLACE_R2_SECRET_KEY
# AWS_STORAGE_BUCKET_NAME=camtraffic-media
# AWS_S3_REGION_NAME=auto
# AWS_S3_ENDPOINT_URL=https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=pub-REPLACE.r2.dev
# AWS_LOCATION=media

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
ENABLE_API_DOCS=False
API_THROTTLE_ANON=60/min
API_THROTTLE_BURST=120/min
API_THROTTLE_SUSTAINED=2000/hour
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW=300

GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

AI_DETECTION_MODE=local
AI_MODEL_PATH=/app/ai/weights/best_v2.pt
AI_USE_MOCK=True
AI_WARMUP_MODELS=False
AI_VEHICLE_ENABLED=False
AI_PLATE_OCR_ENABLED=False
AI_CONFIDENCE_THRESHOLD=0.35
AI_PIPELINE_AUTO_CREATE_VIOLATION=True
GEMINI_ENABLED=False
TTS_ENABLED=True

# OAuth — add callback in Google/GitHub consoles:
#   https://app.camtraffic.store/auth/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

RESEND_API_KEY=REPLACE_RESEND_API_KEY
RESEND_FROM_EMAIL=CamTraffic <noreply@camtraffic.store>
DEFAULT_FROM_EMAIL=CamTraffic <noreply@camtraffic.store>

CAMTRAFFIC_SYNC_DEMO_ACCOUNTS=true
CAMTRAFFIC_BOOTSTRAP_ADMIN_EMAIL=you@example.com
CAMTRAFFIC_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_STRONG_PASSWORD
CAMTRAFFIC_BOOTSTRAP_ADMIN_NAME=Administrator
