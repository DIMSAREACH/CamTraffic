# CamTraffic — production environment (copy to .env.production and fill secrets)
# cp deploy/env/.env.production.example deploy/env/.env.production

# ── Django core ─────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALLOWED_HOSTS=camtraffic.store,www.camtraffic.store,admin.camtraffic.store,app.camtraffic.store,api.camtraffic.store,localhost
DJANGO_SETTINGS_MODULE=camtraffic.settings_production
DJANGO_LOG_LEVEL=INFO
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ── Database (PostgreSQL container) ───────────────────────────────────────────
USE_SQLITE=False
DB_NAME=camtraffic_db
DB_USER=camtraffic
DB_PASSWORD=123456
DB_HOST=postgres
DB_PORT=5432
DB_CONN_MAX_AGE=120

# ── Redis + Celery ────────────────────────────────────────────────────────────
USE_REDIS=True
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── CORS / frontends ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://admin.camtraffic.store,https://app.camtraffic.store

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── API security & docs ───────────────────────────────────────────────────────
ENABLE_API_DOCS=False
API_THROTTLE_ANON=60/min
API_THROTTLE_BURST=120/min
API_THROTTLE_SUSTAINED=2000/hour
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW=300

# ── Production domains (nginx + Certbot) ──────────────────────────────────────
DOMAIN_ROOT=camtraffic.store
DOMAIN_WWW=www.camtraffic.store
DOMAIN_ADMIN=admin.camtraffic.store
DOMAIN_USER=app.camtraffic.store
DOMAIN_API=api.camtraffic.store
CERTBOT_EMAIL=admin@camtraffic.store

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_FRONTEND_CALLBACK_URL=https://app.camtraffic.store/auth/oauth/callback
FRONTEND_PASSWORD_RESET_URL=https://app.camtraffic.store/reset-password

# ── Email (Resend recommended) ────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=CamTraffic <noreply@camtraffic.store>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=CamTraffic <noreply@camtraffic.store>

# ── Gunicorn ──────────────────────────────────────────────────────────────────
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ── AI / detection (monolith — runs in backend + ai-worker) ───────────────────
AI_DETECTION_MODE=local
AI_MODEL_PATH=/app/ai/weights/best_v2.pt
AI_USE_MOCK=False
AI_CONFIDENCE_THRESHOLD=0.35
AI_VEHICLE_ENABLED=True
AI_PLATE_OCR_ENABLED=True
AI_PIPELINE_AUTO_CREATE_VIOLATION=True

# ── Gemini (optional fallback) ────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_ENABLED=False

# ── TTS ───────────────────────────────────────────────────────────────────────
TTS_ENABLED=True

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_ROOT=backups
BACKUP_INCLUDE_AI_WEIGHTS=false

# ── Live fine payments ───────────────────────────────────────────────────────
# PAYMENT_MODE: manual | stripe | khqr | live | auto
# live = Stripe (if STRIPE_* set) + KHQR reference (if KHQR_* set) + optional manual proof
PAYMENT_MODE=live
PAYMENT_CURRENCY=usd
PAYMENT_MANUAL_PROOF_ENABLED=True
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://app.camtraffic.store/fines?paid=1
STRIPE_CANCEL_URL=https://app.camtraffic.store/fines?cancel=1
KHQR_MERCHANT_NAME=CamTraffic Enforcement
KHQR_MERCHANT_ACCOUNT=

# ── Docker compose ports (host) ───────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
