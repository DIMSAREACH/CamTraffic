# CamTraffic Docker environment — copy to .env.docker
# docker compose --env-file .env.docker up -d --build

DEBUG=True
SECRET_KEY=change-me-docker-dev-secret-key-min-50-chars-long
ALLOWED_HOSTS=localhost,127.0.0.1,backend,10.10.101.178

# PostgreSQL (docker-compose service name: postgres)
# Dev: USE_SQLITE=True avoids bigint→uuid migration issues on existing Postgres volumes.
USE_SQLITE=True
USE_REDIS=True
DB_NAME=camtraffic_db
DB_USER=camtraffic
DB_PASSWORD=camtraffic_secret
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
REDIS_PORT=6380

# CORS — localhost + LAN IP for phone testing on same Wi-Fi (update IP if yours changes)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://10.10.101.178:5173,http://10.10.101.178:5174

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# AI (optional in Docker — set AI_USE_MOCK=True if no GPU/weights mounted)
AI_USE_MOCK=False
AI_MODEL_PATH=/app/ai/weights/best.pt
AI_DETECTION_MODE=local

BACKEND_PORT=8000
