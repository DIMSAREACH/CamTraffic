# Docker Compose environment — copy to `.env.docker` at repo root
# Usage: docker compose --env-file .env.docker up -d --build

# ── PostgreSQL (docker-compose service: postgres) ─────────────────
DB_NAME=camtraffic_db
DB_USER=camtraffic
DB_PASSWORD=camtraffic_secret
DB_HOST=postgres
DB_PORT=5432
USE_SQLITE=False

# ── Redis (docker-compose service: redis) ─────────────────────────
USE_REDIS=True
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── Django backend ────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-docker-dev-secret-key-min-32-chars
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DOCKER=1

# CORS — Vite dev servers + Docker host
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── AI (optional — place weights in ai/weights/ locally) ──────────
AI_DETECTION_MODE=local
AI_MODEL_PATH=../ai/weights/best.pt
AI_USE_MOCK=True
AI_VEHICLE_ENABLED=True
AI_PLATE_OCR_ENABLED=True

# ── Email (optional for local Docker) ─────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# API docs in dev
ENABLE_API_DOCS=True
