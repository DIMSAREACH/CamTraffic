# =============================================================================
# CamTraffic — Environment Variables (Master Template)
# Copy to .env:  npm run setup:env
# Validate:     npm run validate:env
# =============================================================================

# ── Environment ──────────────────────────────────────────────────────────────
# development | production | docker
CAMTRAFFIC_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Port 5434 avoids conflict with local PostgreSQL on 5432 (Windows).
POSTGRES_DB=camtraffic_db
POSTGRES_USER=camtraffic
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_CONN_MAX_AGE=0

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ── Django Backend ───────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-use-openssl-rand-hex-32
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000
TIME_ZONE=Asia/Phnom_Penh

# ── JWT (Task 011) ───────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True

# ── Email (Task 020) ─────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@camtraffic.kh
ADMIN_PORTAL_URL=http://localhost:5173
USER_PORTAL_URL=http://localhost:5174

# ── AI Service ───────────────────────────────────────────────────────────────
AI_SERVICE_PORT=8001
AI_SERVICE_URL=http://localhost:8001
AI_MODEL_PATH=/app/models
AI_CONFIDENCE_THRESHOLD=0.75

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
FRONTEND_ADMIN_PORT=5173
FRONTEND_USER_PORT=5174
VITE_API_URL=http://localhost:8000
VITE_AI_SERVICE_URL=http://localhost:8001
VITE_APP_NAME=CamTraffic

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── API ──────────────────────────────────────────────────────────────────────
API_PAGE_SIZE=20

# ── Logging & Monitoring (Task 007) ──────────────────────────────────────────
LOG_FORMAT=verbose
LOG_FILE=
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_LEVEL=INFO
REQUEST_LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true

# ── Security Middleware (Task 024) ────────────────────────────────────────────
SECURITY_LOGIN_RATE_LIMIT_ENABLED=true
SECURITY_LOGIN_RATE_LIMIT_ATTEMPTS=10
SECURITY_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# ── Docker (set automatically in docker-compose) ─────────────────────────────
# CAMTRAFFIC_DOCKER=true
