# CamTraffic — production environment (copy to .env.production and fill secrets)
# cp deploy/env/.env.production.example deploy/env/.env.production
#
# Generate secrets:
#   openssl rand -hex 32          → SECRET_KEY (min 40 chars enforced when DEBUG=False)
#   openssl rand -hex 24          → DB_PASSWORD / REDIS_PASSWORD
#
# NEVER commit the real .env.production file.
# NEVER run seed_demo on public production (known demo password).

# ── Django core ─────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=
ALLOWED_HOSTS=camtraffic.store,www.camtraffic.store,admin.camtraffic.store,app.camtraffic.store,api.camtraffic.store
DJANGO_SETTINGS_MODULE=camtraffic.settings_production
DJANGO_LOG_LEVEL=INFO
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
PUBLIC_API_URL=https://api.camtraffic.store
SERVE_MEDIA=True
USE_S3_MEDIA=False
# When USE_S3_MEDIA=True, set AWS_*/R2 credentials (see backend/.env.example)

# Demo seed must stay false in public production
ALLOW_DEMO_SEED=False
CAMTRAFFIC_SEED_DEMO=False
CAMTRAFFIC_SYNC_DEMO_ACCOUNTS=False

# Bootstrap first admin (preferred over demo accounts)
# CAMTRAFFIC_BOOTSTRAP_ADMIN_EMAIL=you@agency.gov.kh
# CAMTRAFFIC_BOOTSTRAP_ADMIN_PASSWORD=
# CAMTRAFFIC_BOOTSTRAP_ADMIN_NAME=System Administrator

# ── Database (PostgreSQL container) ───────────────────────────────────────────
USE_SQLITE=False
DB_NAME=camtraffic_db
DB_USER=camtraffic
DB_PASSWORD=
DB_HOST=postgres
DB_PORT=5432
DB_CONN_MAX_AGE=120

# ── Redis + Celery ────────────────────────────────────────────────────────────
USE_REDIS=True
# Set REDIS_PASSWORD (openssl rand -hex 24), then use authenticated URLs:
REDIS_PASSWORD=
# No password (dev only): redis://redis:6379/0
# With password:         redis://:YOUR_PASSWORD@redis:6379/0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── CORS / CSRF / frontends ───────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://admin.camtraffic.store,https://app.camtraffic.store
CSRF_TRUSTED_ORIGINS=https://admin.camtraffic.store,https://app.camtraffic.store,https://api.camtraffic.store

# ── JWT (tighten for public internet) ─────────────────────────────────────────
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=3

# ── API security & docs ───────────────────────────────────────────────────────
ENABLE_API_DOCS=False
API_THROTTLE_ANON=60/min
API_THROTTLE_BURST=120/min
API_THROTTLE_SUSTAINED=2000/hour
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW=300

# ── Production domains (nginx + Certbot) ──────────────────────────────────────
DOMAIN_ROOT=camtraffic.store
DOMAIN_WWW=www.camtraffic.store
DOMAIN_ADMIN=admin.camtraffic.store
DOMAIN_USER=app.camtraffic.store
DOMAIN_API=api.camtraffic.store
CERTBOT_EMAIL=admin@camtraffic.store

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_FRONTEND_CALLBACK_URL=https://app.camtraffic.store/auth/oauth/callback
FRONTEND_PASSWORD_RESET_URL=https://app.camtraffic.store/reset-password

# ── Email (Resend recommended) ────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=CamTraffic <noreply@camtraffic.store>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=CamTraffic <noreply@camtraffic.store>

# ── Gunicorn ──────────────────────────────────────────────────────────────────
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ── AI / detection (monolith — runs in backend + ai-worker) ───────────────────
AI_DETECTION_MODE=local
AI_MODEL_PATH=/app/ai/weights/best.pt
AI_USE_MOCK=False
AI_CONFIDENCE_THRESHOLD=0.35
AI_VEHICLE_ENABLED=True
AI_PLATE_OCR_ENABLED=True
# Legal/ops: require officer human review before creating violations/fines
AI_PIPELINE_AUTO_CREATE_VIOLATION=False

# ── Gemini (optional fallback) ────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_ENABLED=False

# ── TTS ───────────────────────────────────────────────────────────────────────
TTS_ENABLED=True

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_ROOT=backups
BACKUP_INCLUDE_AI_WEIGHTS=false

# ── Live fine payments ───────────────────────────────────────────────────────
# PAYMENT_MODE: manual | stripe | khqr | live | auto
# live/auto = Stripe (if key set) + KHQR (if merchant+account) + optional manual
PAYMENT_MODE=live
PAYMENT_CURRENCY=usd
PAYMENT_MANUAL_PROOF_ENABLED=True
# Stripe Dashboard → Developers → Webhooks → https://api.<domain>/api/fines/stripe/webhook/
# Event: checkout.session.completed
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://app.camtraffic.store/citizen/fines?paid=1
STRIPE_CANCEL_URL=https://app.camtraffic.store/citizen/fines?cancel=1
# ABA KHQR: place Receive-QR PNG at src/web/user/public/payments/aba-khqr.png
KHQR_MERCHANT_NAME=CamTraffic Enforcement
KHQR_MERCHANT_ACCOUNT=
KHQR_MERCHANT_ACCOUNT_KHR=
KHQR_QR_IMAGE_URL=/payments/aba-khqr.png

# ── Docker compose ports (host) ───────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
