DEBUG=True
SECRET_KEY=change-me-to-a-long-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=camtraffic_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Use SQLite for quick local dev (set USE_SQLITE=True)
USE_SQLITE=False

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# JWT (minutes)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# OAuth — Google: Cloud Console → Credentials → OAuth client ID (Web app), NOT API key
# Redirect URI in Google must be: http://localhost:5173/auth/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_FRONTEND_CALLBACK_URL=http://localhost:5173/auth/oauth/callback

# Password reset link in emails (user portal)
FRONTEND_PASSWORD_RESET_URL=http://localhost:5173/reset-password

# Resend (recommended) — https://resend.com → API Keys. See docs/RESEND_EMAIL_SETUP.md
RESEND_API_KEY=re_xxxxxxxx
# Must be a full address: Name <user@verified-domain.com>
RESEND_FROM_EMAIL=CamTraffic <noreply@camtraffic.store>

# SMTP fallback (optional if not using Resend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# AI
AI_MODEL_PATH=../ai/weights/best.pt
AI_USE_MOCK=False
AI_CONFIDENCE_THRESHOLD=0.35
AI_MIN_RESULT_CONFIDENCE=35
AI_LIVE_YOLO_FLOOR=10
GEMINI_REQUEST_TIMEOUT=30
GEMINI_BACKOFF_SECONDS=60
AI_UPLOAD_YOLO_FLOOR=5
AI_HYBRID_CONFIDENCE_THRESHOLD=70

# Vehicle detection (YOLOv8 COCO — cars, motorcycles, buses, trucks)
AI_VEHICLE_ENABLED=True
AI_VEHICLE_MODEL=yolov8n.pt
AI_VEHICLE_CONFIDENCE_THRESHOLD=0.35

# License plate OCR (EasyOCR — Cambodia Latin plates e.g. 2A-1234)
AI_PLATE_OCR_ENABLED=True
AI_PLATE_OCR_MIN_CONFIDENCE=0.45
AI_PLATE_OCR_LANGUAGES=en

# Full demo pipeline — auto violation check + record when plate links to a driver
AI_PIPELINE_DEMO_VIOLATION=True
AI_PIPELINE_AUTO_CREATE_VIOLATION=True

# Gemini Vision (fallback when YOLO confidence < 70%)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_ENABLED=True
GEMINI_MODEL=gemini-2.5-flash

# Khmer TTS (edge-tts; needs internet — auto-retries if Windows SSL certs fail)
TTS_ENABLED=True
TTS_VOICE=km-KH-SreymomNeural
